{
  "name": "@dv.net/ui-kit",
  "private": false,
  "version": "7.6.3",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/style.css": "./dist/style.css",
    "./style.css": "./dist/style.css",
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "style": "dist/style.css",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --p ./tsconfig-build.json && vite build",
    "build-only": "vite build",
    "build-demo": "vite build --mode demo",
    "lint": "eslint . && npx stylelint \"**/*.{vue,css,scss}\"",
    "lint:fix": "eslint . --fix && npx stylelint \"**/*.{vue,css,scss}\" --fix",
    "generate-svg-list": "node generate-svg-list.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dv-net/ui-kit.git"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "vue": ">=3.5.32",
    "vue-router": ">=5.0.4"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@vuepic/vue-datepicker": "^12.1.0",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "maska": "^3.2.0",
    "uuidv7": "^1.2.1",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-virtual-scroller": "^2.0.1",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node18": "^18.2.6",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
